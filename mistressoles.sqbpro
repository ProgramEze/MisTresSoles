<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="mistressoles.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="0"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="2464"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="detalle_movimiento" custom_title="0" dock_id="1" table="4,18:maindetalle_movimiento"/><dock_state state="000000ff00000000fd00000001000000020000000000000000fc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000ffffffff0000011e00ffffff000000000000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings/></tab_browse><tab_sql><sql name="SQL 1*">-- Tabla cabecera: Guarda la fecha y el total del ticket
CREATE TABLE &quot;ventas&quot; (
	&quot;id_venta&quot;	INTEGER,
	&quot;fecha&quot;	TEXT DEFAULT CURRENT_TIMESTAMP,
	&quot;total&quot;	REAL,
	PRIMARY KEY(&quot;id_venta&quot; AUTOINCREMENT)
);

-- Tabla detalle: Guarda cada ítem del ticket
CREATE TABLE &quot;detalle_ventas&quot; (
	&quot;id_detalle&quot;	INTEGER,
	&quot;id_venta&quot;	INTEGER,
	&quot;id_producto&quot;	INTEGER,
	&quot;cantidad&quot;	REAL,
	&quot;precio_unitario&quot;	REAL,
	&quot;subtotal&quot;	REAL,
	PRIMARY KEY(&quot;id_detalle&quot; AUTOINCREMENT),
	FOREIGN KEY(&quot;id_venta&quot;) REFERENCES &quot;ventas&quot;(&quot;id_venta&quot;),
	FOREIGN KEY(&quot;id_producto&quot;) REFERENCES &quot;productos&quot;(&quot;id_producto&quot;)
);</sql><current_tab id="0"/></tab_sql></sqlb_project>
