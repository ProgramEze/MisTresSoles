<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="700.0" prefWidth="1280.0" spacing="15.0" style="-fx-background-color: #f5f5f5;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mistressoles.controller.VentaController">
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>
   <children>
      <VBox prefWidth="600.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 5; -fx-border-color: #ddd; -fx-border-radius: 5;" HBox.hgrow="ALWAYS">
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
         <children>
            <Label text="Buscar Producto" textFill="#333333">
               <font><Font name="System Bold" size="18.0" /></font>
            </Label>
            <HBox spacing="10.0">
               <children>
                  <TextField fx:id="txtBuscar" prefHeight="35.0" promptText="Nombre del producto..." HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#limpiarBuscador" prefHeight="35.0" text="Limpiar" />
               </children>
            </HBox>
            <TableView fx:id="tablaBusqueda" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colBusqNombre" prefWidth="180.0" text="Producto" />
                <TableColumn fx:id="colBusqStock" prefWidth="70.0" style="-fx-alignment: CENTER;" text="Stock" />
                <TableColumn fx:id="colBusqUnidad" prefWidth="70.0" style="-fx-alignment: CENTER;" text="Unidad" />
                <TableColumn fx:id="colBusqPrecio" prefWidth="90.0" style="-fx-alignment: CENTER;" text="Precio ($)" />
              </columns>
            </TableView>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label text="Cantidad:" />
                  <TextField fx:id="txtCantidad" prefHeight="35.0" prefWidth="80.0" text="1" />
                  <Button mnemonicParsing="false" onAction="#agregarProducto" prefHeight="35.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;" text="➡ Agregar al Ticket" />
               </children>
            </HBox>
         </children>
      </VBox>

      <VBox prefWidth="500.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 5; -fx-border-color: #ddd; -fx-border-radius: 5;" HBox.hgrow="ALWAYS">
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
         <children>
            <Label text="Ticket de Venta" textFill="#333333">
               <font><Font name="System Bold" size="18.0" /></font>
            </Label>
            <TableView fx:id="tablaTicket" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colTicketProducto" prefWidth="180.0" text="Producto" />
                <TableColumn fx:id="colTicketCant" prefWidth="70.0" style="-fx-alignment: CENTER;" text="Cant." />
                <TableColumn fx:id="colTicketPrecio" prefWidth="90.0" style="-fx-alignment: CENTER;" text="Precio U." />
                <TableColumn fx:id="colTicketSubtotal" prefWidth="90.0" style="-fx-alignment: CENTER;" text="Subtotal" />
              </columns>
            </TableView>
            <HBox alignment="CENTER_RIGHT">
               <children>
                  <Label text="TOTAL: " textFill="#333333">
                     <font><Font name="System Bold" size="24.0" /></font>
                  </Label>
                  <Label fx:id="lblTotal" text="\$ 0.00" textFill="#2e7d32">
                     <font><Font name="System Bold" size="32.0" /></font>
                  </Label>
               </children>
            </HBox>
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <children>
                  <Label text="Abona con: $" />
                  <TextField fx:id="txtAbona" prefHeight="35.0" prefWidth="100.0" promptText="0.00" />
                  <Label fx:id="lblVuelto" prefWidth="150.0" text="Vuelto: $ 0.00">
                     <font><Font name="System Bold" size="14.0" /></font>
                  </Label>
               </children>
            </HBox>
            <HBox alignment="CENTER" spacing="15.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#cancelarVenta" prefHeight="45.0" prefWidth="150.0" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-weight: bold;" text="Cancelar Venta" />
                  <Button mnemonicParsing="false" onAction="#finalizarVenta" prefHeight="45.0" prefWidth="250.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px;" text="COBRAR" />
               </children>
            </HBox>
            <HBox alignment="CENTER">
               <children>
                  <Label fx:id="lblMensaje" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</HBox>