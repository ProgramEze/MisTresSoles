<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mistressoles.controller.VentaController">
   <children>
      <SplitPane dividerPositions="0.45" layoutX="200.0" layoutY="120.0" prefHeight="600.0" prefWidth="1000.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <items>
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="160.0" prefWidth="100.0">
               <children>
                  <VBox layoutX="57.0" layoutY="58.0" prefHeight="598.0" prefWidth="446.0" spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                     <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                     </padding>
                     <children>
                        <Label text="1. Seleccionar Producto">
                           <font>
                              <Font name="System Bold" size="16.0" />
                           </font>
                        </Label>
                        <TextField fx:id="txtBuscar" promptText="Escribe para buscar..." />
                        
                        <TableView fx:id="tablaBusqueda" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="colBusqNombre" prefWidth="75.0" text="Nombre" />
                            <TableColumn fx:id="colBusqPrecio" prefWidth="75.0" text="Precio" />
                            <TableColumn fx:id="colBusqStock" prefWidth="75.0" text="Stock" />
                          </columns>
                        </TableView>

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <Label text="Cantidad:">
                                 <font>
                                    <Font size="14.0" />
                                 </font>
                              </Label>
                              <HBox alignment="CENTER" spacing="10.0">
                                 <children>
                                    <TextField fx:id="txtCantidad" prefHeight="30.0" prefWidth="100.0" text="1" HBox.hgrow="ALWAYS" />
                                    <Button mnemonicParsing="false" onAction="#limpiarBuscador" text="X" />
                                 </children>
                              </HBox>
                              <Button fx:id="btnAgregar" mnemonicParsing="false" onAction="#agregarProducto" prefHeight="30.0" prefWidth="120.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="AGREGAR ➡" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </AnchorPane>
            
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="160.0" prefWidth="100.0" style="-fx-background-color: #f4f4f4;">
               <children>
                  <VBox layoutX="123.0" layoutY="86.0" prefHeight="598.0" prefWidth="546.0" spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                     <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                     </padding>
                     <children>
                        <Label text="2. Ticket de Venta">
                           <font>
                              <Font name="System Bold" size="16.0" />
                           </font>
                        </Label>
                        
                        <TableView fx:id="tablaTicket" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="colTicketProducto" prefWidth="150.0" text="Producto" />
                            <TableColumn fx:id="colTicketCant" prefWidth="60.0" text="Cant." />
                            <TableColumn fx:id="colTicketPrecio" prefWidth="80.0" text="Unitario" />
                            <TableColumn fx:id="colTicketSubtotal" prefWidth="80.0" text="Subtotal" />
                          </columns>
                        </TableView>

                        <HBox alignment="CENTER_RIGHT" prefHeight="60.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 5; -fx-border-color: #ddd; -fx-border-radius: 5;">
                           <children>
                              <Label text="TOTAL A PAGAR:">
                                 <font>
                                    <Font size="18.0" />
                                 </font>
                              </Label>
                              <Label fx:id="lblTotal" text="\$ 0.00" textFill="#2e7d32">
                                 <font>
                                    <Font name="System Bold" size="36.0" />
                                 </font>
                              </Label>
                           </children>
                           <padding>
                              <Insets right="20.0" />
                           </padding>
                        </HBox>
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#cancelarVenta" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #ffcccc; -fx-text-fill: red;" text="Cancelar" />
                              <Button mnemonicParsing="false" onAction="#finalizarVenta" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;" text="✅ COBRAR" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </AnchorPane>
        </items>
      </SplitPane>
   </children>
</AnchorPane>
