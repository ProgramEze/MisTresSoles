<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="300.0" prefWidth="400.0" spacing="10.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mistressoles.controller.NuevoProductoController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
      <Label alignment="CENTER" text="Nombre del producto">
         <VBox.margin>
            <Insets />
         </VBox.margin>
      </Label>
      <TextField fx:id="txtNombre" onMouseClicked="#onEmpezarEscritura" prefWidth="200.0" promptText="&quot;Manzanas&quot;" />
      <Label text="Stock inicial" />
      <TextField fx:id="txtStock" alignment="CENTER_RIGHT" prefWidth="200.0" promptText="&quot;10&quot;" />
      <Label text="Precio" />
      <TextField fx:id="txtPrecio" alignment="CENTER_RIGHT" prefWidth="200.0" promptText="&quot;1050.50&quot;" />
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="100.0">
         <children>
            <Button fx:id="btnCancelar" mnemonicParsing="false" onAction="#onCancelarClick" text="Cancelar" />
            <Button fx:id="btnGuardar" defaultButton="true" mnemonicParsing="false" onAction="#onGuardarClick" style="-fx-background-color: #2196F3; -fx-text-fill: white;" text="Guardar" />
         </children>
      </HBox>
      <Label fx:id="lblMensaje" alignment="CENTER" textAlignment="CENTER" wrapText="true" />
   </children>
</VBox>
