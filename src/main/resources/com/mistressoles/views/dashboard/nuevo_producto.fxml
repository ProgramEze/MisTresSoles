<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefWidth="400.0" spacing="15.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mistressoles.controller.NuevoProductoController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <Label text="Datos del Producto">
         <font>
            <Font name="System Bold" size="20.0" />
         </font>
         <VBox.margin>
            <Insets bottom="10.0" />
         </VBox.margin>
      </Label>
      
      <VBox spacing="5.0">
         <Label text="Nombre del Producto:" />
         <TextField fx:id="txtNombre" onMouseClicked="#onEmpezarEscritura" promptText="Ej: Manzanas" />
      </VBox>
      
      <VBox spacing="5.0">
         <Label text="Categoría:" />
         <ComboBox fx:id="cbCategoria" prefWidth="400.0" promptText="Seleccionar..." />
      </VBox>

      <HBox spacing="15.0">
         <children>
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
               <Label text="Stock Actual:" />
               <TextField fx:id="txtStock" onMouseClicked="#onEmpezarEscritura" promptText="0.00" />
            </VBox>
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
               <Label text="Unidad:" />
               <ComboBox fx:id="cbUnidad" prefWidth="150.0" promptText="kg / unid" />
            </VBox>
         </children>
      </HBox>

      <HBox spacing="15.0">
         <children>
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
               <Label text="Precio Venta ($):" />
               <TextField fx:id="txtPrecio" onMouseClicked="#onEmpezarEscritura" promptText="0.00" />
            </VBox>
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
               <Label text="Stock Mínimo:" />
               <TextField fx:id="txtStockMinimo" onMouseClicked="#onEmpezarEscritura" promptText="Ej: 5.0" text="2.0" />
            </VBox>
         </children>
      </HBox>

      <Label fx:id="lblMensaje" minHeight="20.0" textFill="RED" wrapText="true">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>

      <HBox alignment="CENTER" spacing="20.0">
         <children>
            <Button fx:id="btnCancelar" mnemonicParsing="false" onAction="#onCancelarClick" prefWidth="120.0" style="-fx-background-color: #f5f5f5; -fx-border-color: #ccc; -fx-border-radius: 3;" text="Cancelar" />
            <Button fx:id="btnGuardar" mnemonicParsing="false" onAction="#onGuardarClick" prefWidth="120.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="Guardar" />
         </children>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </HBox>
   </children>
</VBox>